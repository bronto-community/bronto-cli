# syntax=docker/dockerfile:1
# Release image: expects PREBUILT per-arch binaries — see Dockerfile for
# the rationale (no QEMU compilation) and the staging layout.
FROM gcr.io/distroless/static:nonroot@sha256:f7f8f729987ad0fdf6b05eeeae94b26e6a0f613bdf46feea7fc40f7bd72953e6
ARG TARGETPLATFORM
ARG VERSION=dev
ARG COMMIT=none
LABEL org.opencontainers.image.source="https://github.com/bronto-community/bronto-cli" \
	org.opencontainers.image.description="Community CLI for the Bronto observability platform (distroless)" \
	org.opencontainers.image.licenses="MIT" \
	org.opencontainers.image.version="${VERSION}" \
	org.opencontainers.image.revision="${COMMIT}"
COPY ${TARGETPLATFORM}/bronto /bronto
ENTRYPOINT ["/bronto"]
